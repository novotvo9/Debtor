<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Debtor</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-fluid app-shell py-0">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    Debtor
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 app-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>

                            @if (User.FindFirst("email") != null && User.FindFirst("email")!.Value == "admin@hostmaster.com")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Accounts" asp-action="All">Accounts</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Transactions" asp-action="All">Transactions</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Users" asp-action="All">Users</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto app-nav-right">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="app-user-pill">
                                    @User.FindFirst("email")?.Value
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Users" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Users" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Users" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main">
        <div class="app-shell">
            @RenderBody()
        </div>
    </main>

    <footer class="footer">
        <div class="app-shell py-0">
            &copy; 2026 - Debtor - Vojtěch Novotný IV.C -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
