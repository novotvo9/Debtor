@using Debtor.Web.Models.Transactions
@model TransactionsCreateViewModel

@{
    ViewData["Title"] = "Transaction Create";
}

<form method="post">
    <label for="accountId" class="form-label">Account ID:</label>
    @if (User.Identity!.IsAuthenticated)
    {
            if (Model.IsNonAdmin == false)
            {
                <select asp-for="AccountId" class="form-select" id="accountId">
                    @foreach (Account account in Model.Accounts!)
                    {
                        <option value="@account.Id">
                            @account.Id
                        </option>
                    }
                </select>
            }
            else
            {
            <select asp-for="AccountId" class="form-select" id="accountId">
                <option value="@Model.UsersGuid" selected>
                            @Model.UsersGuid
                        </option>
                </select>
            }
    }

    <label for="transactionType" class="form-label">Transation Type:</label>
    <select asp-for="TransactionType" class="form-select" id="transactionType">
        <option selected value="payment">payment</option>
        <option value="borrow">borrow</option>
    </select>

    <div class="mb-3">
        <label for="amount" class="form-label">Amount:</label>
        <input asp-for="Amount" type="number" class="form-control" id="amount" value="1" min="1" max="9999999999999999.99">
    </div>

    @if (User.Identity!.IsAuthenticated)
    {
        if (Model.PreviousCurrency == "!")
        {
            <div class="mb-3">
                <label for="currency" class="form-label">Currency:</label>
                <input asp-for="Currency" type="text" class="form-control" id="currency" maxlength="3">
            </div>
        }
        else
        {
            <div class="mb-3">
                <label for="currency" class="form-label">Currency:</label>
                <input asp-for="Currency" type="text" class="form-control" id="currency" maxlength="3" readonly value="@Model.PreviousCurrency">
            </div>
        }
    }

    <label for="paymentMethod" class="form-label">Payment Method:</label>
    <select asp-for="PaymentMethod" class="form-select" id="paymentMethod">
        <option selected value="bank">bank</option>
        <option value="cash">cash</option>
    </select>

    <button class="btn btn-primary mt-3" type="submit">Submit</button>
    <button class="btn btn-warning mt-3" type="reset">Reset</button>
</form>