@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="page-header">
    <div class="page-header-text">
        <h1>Privacy Policy</h1>
        <p>Basic information about data handling within the Debtor application.</p>
    </div>
</div>

<div class="app-card" style="max-width: 900px;">
    <h2 class="app-card-title">Data Usage</h2>
    <p class="text-muted-soft">
        This application stores only the information required for account and transaction management.
        The purpose of collected data is to support debtor records, transaction history and user access.
    </p>

    <div class="section-gap">
        <h3 class="app-card-title" style="font-size:1.05rem;">Stored Information</h3>
        <p class="mb-2">
            The application may contain personal and account-related data such as full name, email address,
            phone number, account type and transaction records.
        </p>
    </div>

    <div class="section-gap">
        <h3 class="app-card-title" style="font-size:1.05rem;">Access and Responsibility</h3>
        <p class="mb-2">
            Access to data is limited according to user role. Administrative users can manage records globally,
            while standard users only work with data connected to their own account.
        </p>
    </div>

    <div class="section-gap">
        <h3 class="app-card-title" style="font-size:1.05rem;">Current State</h3>
        <p class="mb-0">
            This privacy section is a simplified project version and may be expanded later with more precise
            legal, retention and security information.
        </p>
    </div>
</div>