@{
    ViewData["Title"] = "Home Page";
}

<div class="page-header">
    <div class="page-header-text">
        <h1>Debtor</h1>
        <p>Simple debtor account and transaction management in a clean administrative environment.</p>
    </div>
</div>

<div class="stat-grid">
    <div class="stat-box">
        <div class="stat-label">Accounts</div>
        <div class="stat-value">Manage</div>
    </div>
    <div class="stat-box">
        <div class="stat-label">Transactions</div>
        <div class="stat-value">Track</div>
    </div>
    <div class="stat-box">
        <div class="stat-label">Users</div>
        <div class="stat-value">Access</div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="app-card h-100">
            <h2 class="app-card-title">Application Overview</h2>
            <p class="app-card-subtitle">
                Debtor is focused on managing accounts, debts and payments through a simple MVC interface.
            </p>

            <p>
                The project is designed as a straightforward administrative tool for keeping track of debtor data,
                transaction records and user access. The interface is intentionally minimal, readable and centered
                around practical CRUD operations.
            </p>

            <p class="mb-0">
                The goal is clarity, not visual overload. Everything important should stay visible,
                understandable and easy to maintain.
            </p>
        </div>
    </div>
</div>